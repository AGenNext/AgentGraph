UPSERT schema_term:enumeration_value_schema_caseseries CONTENT {"term_key": "enumeration_value_schema_caseseries", "source_id": "schema:CaseSeries", "term_kind": "enumeration_value", "label": "CaseSeries", "comment": "A case series (also known as a clinical series) is a medical research study that tracks patients with a known exposure given similar treatment or examines their medical records for exposure and outcome. A case series can be retrospective or prospective and usually involves a smaller number of patients than the more powerful case-control studies or randomized controlled trials. Case series may be consecutive or non-consecutive, depending on whether all cases presenting to the reporting authors over a period of time were included, or only a selection.", "url": "https://schema.org/CaseSeries", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["schema:MedicalObservationalStudyDesign"], "parent_source_ids": ["schema:MedicalObservationalStudyDesign"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
