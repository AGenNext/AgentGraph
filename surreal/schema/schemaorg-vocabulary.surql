UPSERT schema_term:class_schema_publictoilet CONTENT {"term_key": "class_schema_publictoilet", "source_id": "schema:PublicToilet", "term_kind": "class", "label": "PublicToilet", "comment": "A public toilet is a room or small building containing one or more toilets (and possibly also urinals) which is available for use by the general public, or by customers or employees of certain businesses.", "url": "https://schema.org/PublicToilet", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1624"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CivicStructure"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_publicationevent CONTENT {"term_key": "class_schema_publicationevent", "source_id": "schema:PublicationEvent", "term_kind": "class", "label": "PublicationEvent", "comment": "A PublicationEvent corresponds indifferently to the event of publication for a CreativeWork of any type, e.g. a broadcast event, an on-demand event, a book/journal publication via a variety of delivery media.", "url": "https://schema.org/PublicationEvent", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Event"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_publicationissue CONTENT {"term_key": "class_schema_publicationissue", "source_id": "schema:PublicationIssue", "term_kind": "class", "label": "PublicationIssue", "comment": "A part of a successively published publication such as a periodical or publication volume, often numbered, usually containing a grouping of works such as articles.\\n\\nSee also [blog post](https://blog-schema.org/2014/09/02/schema-org-support-for-bibliographic-relationships-and-periodicals/).", "url": "https://schema.org/PublicationIssue", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/bibex"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_publicationvolume CONTENT {"term_key": "class_schema_publicationvolume", "source_id": "schema:PublicationVolume", "term_kind": "class", "label": "PublicationVolume", "comment": "A part of a successively published publication such as a periodical or multi-volume work, often numbered. It may represent a time span, such as a year.\\n\\nSee also [blog post](https://blog-schema.org/2014/09/02/schema-org-support-for-bibliographic-relationships-and-periodicals/).", "url": "https://schema.org/PublicationVolume", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/bibex"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
