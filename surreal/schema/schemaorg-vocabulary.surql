UPSERT schema_term:class_schema_creativeworkseason CONTENT {"term_key": "class_schema_creativeworkseason", "source_id": "schema:CreativeWorkSeason", "term_kind": "class", "label": "CreativeWorkSeason", "comment": "A media season, e.g. TV, radio, video game etc.", "url": "https://schema.org/CreativeWorkSeason", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_creativeworkseries CONTENT {"term_key": "class_schema_creativeworkseries", "source_id": "schema:CreativeWorkSeries", "term_kind": "class", "label": "CreativeWorkSeries", "comment": "A CreativeWorkSeries in schema.org is a group of related items, typically but not necessarily of the same kind. CreativeWorkSeries are usually organized into some order, often chronological. Unlike [[ItemList]] which is a general purpose data structure for lists of things, the emphasis with CreativeWorkSeries is on published materials (written e.g. books and periodicals, or media such as TV, radio and games).\\n\\nSpecific subtypes are available for describing [[TVSeries]], [[RadioSeries]], [[MovieSeries]], [[BookSeries]], [[Periodical]] and [[VideoGameSeries]]. In each case, the [[hasPart]] / [[isPartOf]] properties can be used to relate the CreativeWorkSeries to its parts. The general CreativeWorkSeries type serves largely just to organize these more specific and practical subtypes.\\n\\nIt is common for properties applicable to an item from the series to be usefully applied to the containing group. Schema.org attempts to anticipate some of these cases, but publishers should be free to apply properties of the series parts to the series as a whole wherever they seem appropriate.\n    ", "url": "https://schema.org/CreativeWorkSeries", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Series", "schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_credential CONTENT {"term_key": "class_schema_credential", "source_id": "schema:Credential", "term_kind": "class", "label": "Credential", "comment": "A credential is a certificate that is used to verify the identity of a person or entity.", "url": "https://schema.org/Credential", "is_part_of": "https://pending.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_creditcard CONTENT {"term_key": "class_schema_creditcard", "source_id": "schema:CreditCard", "term_kind": "class", "label": "CreditCard", "comment": "A card payment method of a particular brand or name.  Used to mark up a particular payment method and/or the financial product/service that supplies the card account.\\n\\nCommonly used values:\\n\\n* http://purl.org/goodrelations/v1#AmericanExpress\\n* http://purl.org/goodrelations/v1#DinersClub\\n* http://purl.org/goodrelations/v1#Discover\\n* http://purl.org/goodrelations/v1#JCB\\n* http://purl.org/goodrelations/v1#MasterCard\\n* http://purl.org/goodrelations/v1#VISA\n       ", "url": "https://schema.org/CreditCard", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/FIBO", "https://blog.schema.org/2012/11/08/good-relations-and-schema-org/"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:PaymentCard", "schema:LoanOrCredit"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
