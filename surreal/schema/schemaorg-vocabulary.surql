UPSERT schema_term:property_schema_previousstartdate CONTENT {"term_key": "property_schema_previousstartdate", "source_id": "schema:previousStartDate", "term_kind": "property", "label": "previousStartDate", "comment": "Used in conjunction with eventStatus for rescheduled or cancelled events. This property contains the previously scheduled start date. For rescheduled events, the startDate property should be used for the newly scheduled start date. In the (rare) case of an event that has been postponed and rescheduled multiple times, this field may be repeated.", "url": "https://schema.org/previousStartDate", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Event"], "range_source_ids": ["schema:DateTime", "schema:Date"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_price CONTENT {"term_key": "property_schema_price", "source_id": "schema:price", "term_kind": "property", "label": "price", "comment": "The offer price of a product, or of a price component when attached to PriceSpecification and its subtypes.\\n\\nUsage guidelines:\\n\\n* Use the [[priceCurrency]] property (with standard formats: [ISO 4217 currency format](http://en.wikipedia.org/wiki/ISO_4217), e.g. \"USD\"; [Ticker symbol](https://en.wikipedia.org/wiki/List_of_cryptocurrencies) for cryptocurrencies, e.g. \"BTC\"; well known names for [Local Exchange Trading Systems](https://en.wikipedia.org/wiki/Local_exchange_trading_system) (LETS) and other currency types, e.g. \"Ithaca HOUR\") instead of including [ambiguous symbols](http://en.wikipedia.org/wiki/Dollar_sign#Currencies_that_use_the_dollar_or_peso_sign) such as '$' in the value.\\n* Use '.' (Unicode 'FULL STOP' (U+002E)) rather than ',' to indicate a decimal point. Avoid using these symbols as a readability separator.\\n* Note that both [RDFa](http://www.w3.org/TR/xhtml-rdfa-primer/#using-the-content-attribute) and Microdata syntax allow the use of a \"content=\" attribute for publishing simple machine-readable values alongside more human-friendly formatting.\\n* Use values from 0123456789 (Unicode 'DIGIT ZERO' (U+0030) to 'DIGIT NINE' (U+0039)) rather than superficially similar Unicode symbols.\n      ", "url": "https://schema.org/price", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["cmns-q:hasNumericValue", "fibo-fnd-acc-cur:hasAmount"], "domain_source_ids": ["schema:PriceSpecification", "schema:TradeAction", "schema:DonateAction", "schema:Offer"], "range_source_ids": ["schema:Text", "schema:Number"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_pricecomponent CONTENT {"term_key": "property_schema_pricecomponent", "source_id": "schema:priceComponent", "term_kind": "property", "label": "priceComponent", "comment": "This property links to all [[UnitPriceSpecification]] nodes that apply in parallel for the [[CompoundPriceSpecification]] node.", "url": "https://schema.org/priceComponent", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:CompoundPriceSpecification"], "range_source_ids": ["schema:PriceSpecification"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_pricecomponenttype CONTENT {"term_key": "property_schema_pricecomponenttype", "source_id": "schema:priceComponentType", "term_kind": "property", "label": "priceComponentType", "comment": "Identifies a price component (for example, a line item on an invoice), part of the total price for an offer.", "url": "https://schema.org/priceComponentType", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2689"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:UnitPriceSpecification"], "range_source_ids": ["schema:PriceComponentTypeEnumeration"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_pricecurrency CONTENT {"term_key": "property_schema_pricecurrency", "source_id": "schema:priceCurrency", "term_kind": "property", "label": "priceCurrency", "comment": "The currency of the price, or a price component when attached to [[PriceSpecification]] and its subtypes.\\n\\nUse standard formats: [ISO 4217 currency format](http://en.wikipedia.org/wiki/ISO_4217), e.g. \"USD\"; [Ticker symbol](https://en.wikipedia.org/wiki/List_of_cryptocurrencies) for cryptocurrencies, e.g. \"BTC\"; well known names for [Local Exchange Trading Systems](https://en.wikipedia.org/wiki/Local_exchange_trading_system) (LETS) and other currency types, e.g. \"Ithaca HOUR\".", "url": "https://schema.org/priceCurrency", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["fibo-fnd-acc-cur:hasCurrency"], "domain_source_ids": ["schema:Ticket", "schema:TradeAction", "schema:DonateAction", "schema:Offer", "schema:Reservation", "schema:PriceSpecification"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_pricerange CONTENT {"term_key": "property_schema_pricerange", "source_id": "schema:priceRange", "term_kind": "property", "label": "priceRange", "comment": "The price range of the business, for example ```$$$```.", "url": "https://schema.org/priceRange", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:LocalBusiness"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_pricespecification CONTENT {"term_key": "property_schema_pricespecification", "source_id": "schema:priceSpecification", "term_kind": "property", "label": "priceSpecification", "comment": "One or more detailed price specifications, indicating the unit price and delivery or payment charges.", "url": "https://schema.org/priceSpecification", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:DonateAction", "schema:Offer", "schema:Demand", "schema:TradeAction"], "range_source_ids": ["schema:PriceSpecification"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_pricetype CONTENT {"term_key": "property_schema_pricetype", "source_id": "schema:priceType", "term_kind": "property", "label": "priceType", "comment": "Defines the type of a price specified for an offered product, for example a list price, a (temporary) sale price or a manufacturer suggested retail price. If multiple prices are specified for an offer the [[priceType]] property can be used to identify the type of each such specified price. The value of priceType can be specified as a value from enumeration PriceTypeEnumeration or, a UN/EDIFACT 5387 code, or as a free form text string for price types that are not already predefined in PriceTypeEnumeration.", "url": "https://schema.org/priceType", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["cmns-cls:isClassifiedBy"], "domain_source_ids": ["schema:CompoundPriceSpecification", "schema:UnitPriceSpecification"], "range_source_ids": ["schema:Text", "schema:PriceTypeEnumeration"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
