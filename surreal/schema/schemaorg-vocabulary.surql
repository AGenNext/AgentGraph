UPSERT schema_term:enumeration_schema_governmentbenefitstype CONTENT {"term_key": "enumeration_schema_governmentbenefitstype", "source_id": "schema:GovernmentBenefitsType", "term_kind": "enumeration", "label": "GovernmentBenefitsType", "comment": "GovernmentBenefitsType enumerates several kinds of government benefits to support the COVID-19 situation. Note that this structure may not capture all benefits offered.", "url": "https://schema.org/GovernmentBenefitsType", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2534"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Enumeration"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:enumeration_schema_healthaspectenumeration CONTENT {"term_key": "enumeration_schema_healthaspectenumeration", "source_id": "schema:HealthAspectEnumeration", "term_kind": "enumeration", "label": "HealthAspectEnumeration", "comment": "HealthAspectEnumeration enumerates several aspects of health content online, each of which might be described using [[hasHealthAspect]] and [[HealthTopicContent]].", "url": "https://schema.org/HealthAspectEnumeration", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2374"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Enumeration"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:enumeration_schema_iptcdigitalsourceenumeration CONTENT {"term_key": "enumeration_schema_iptcdigitalsourceenumeration", "source_id": "schema:IPTCDigitalSourceEnumeration", "term_kind": "enumeration", "label": "IPTCDigitalSourceEnumeration", "comment": "<a href=\"https://www.iptc.org/\">IPTC</a> \"Digital Source\" codes for use with the [[digitalSourceType]] property, providing information about the source for a digital media object.\nIn general these codes are not declared here to be mutually exclusive, although some combinations would be contradictory if applied simultaneously, or might be considered mutually incompatible by upstream maintainers of the definitions. See the IPTC <a href=\"https://www.iptc.org/std/photometadata/documentation/userguide/\">documentation</a>\n for <a href=\"https://cv.iptc.org/newscodes/digitalsourcetype/\">detailed definitions</a> of all terms.", "url": "https://schema.org/IPTCDigitalSourceEnumeration", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/3392"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MediaEnumeration"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
