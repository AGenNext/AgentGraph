UPSERT schema_term:class_schema_course CONTENT {"term_key": "class_schema_course", "source_id": "schema:Course", "term_kind": "class", "label": "Course", "comment": "A description of an educational course which may be offered as distinct instances which take place at different times or take place at different locations, or be offered through different media or modes of study. An educational course is a sequence of one or more educational events and/or creative works which aims to build knowledge, competence or ability of learners.", "url": "https://schema.org/Course", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:LearningResource", "schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
