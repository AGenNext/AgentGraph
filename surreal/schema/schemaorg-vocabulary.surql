UPSERT schema_term:property_schema_encodingformat CONTENT {"term_key": "property_schema_encodingformat", "source_id": "schema:encodingFormat", "term_kind": "property", "label": "encodingFormat", "comment": "Media type typically expressed using a MIME format (see [IANA site](http://www.iana.org/assignments/media-types/media-types.xhtml) and [MDN reference](https://developer.mozilla.org/en-US/docs/Web/HTTP/Basics_of_HTTP/MIME_types)), e.g. application/zip for a SoftwareApplication binary, audio/mpeg for .mp3 etc.\n\nIn cases where a [[CreativeWork]] has several media type representations, [[encoding]] can be used to indicate each [[MediaObject]] alongside particular [[encodingFormat]] information.\n\nUnregistered or niche encoding and file formats can be indicated instead via the most appropriate URL, e.g. defining Web page or a Wikipedia/Wikidata entry.", "url": "https://schema.org/encodingFormat", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:MediaObject", "schema:CreativeWork"], "range_source_ids": ["schema:Text", "schema:URL"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
