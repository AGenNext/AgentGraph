UPSERT schema_term:class_schema_replaceaction CONTENT {"term_key": "class_schema_replaceaction", "source_id": "schema:ReplaceAction", "term_kind": "class", "label": "ReplaceAction", "comment": "The act of editing a recipient by replacing an old object with a new object.", "url": "https://schema.org/ReplaceAction", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:UpdateAction"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_replyaction CONTENT {"term_key": "class_schema_replyaction", "source_id": "schema:ReplyAction", "term_kind": "class", "label": "ReplyAction", "comment": "The act of responding to a question/message asked/sent by the object. Related to [[AskAction]].\\n\\nRelated actions:\\n\\n* [[AskAction]]: Appears generally as an origin of a ReplyAction.", "url": "https://schema.org/ReplyAction", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CommunicateAction"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_report CONTENT {"term_key": "class_schema_report", "source_id": "schema:Report", "term_kind": "class", "label": "Report", "comment": "A Report generated by governmental or non-governmental organization.", "url": "https://schema.org/Report", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Article"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_reportagenewsarticle CONTENT {"term_key": "class_schema_reportagenewsarticle", "source_id": "schema:ReportageNewsArticle", "term_kind": "class", "label": "ReportageNewsArticle", "comment": "The [[ReportageNewsArticle]] type is a subtype of [[NewsArticle]] representing\n news articles which are the result of journalistic news reporting conventions.\n\nIn practice many news publishers produce a wide variety of article types, many of which might be considered a [[NewsArticle]] but not a [[ReportageNewsArticle]]. For example, opinion pieces, reviews, analysis, sponsored or satirical articles, or articles that combine several of these elements.\n\nThe [[ReportageNewsArticle]] type is based on a stricter ideal for \"news\" as a work of journalism, with articles based on factual information either observed or verified by the author, or reported and verified from knowledgeable sources.  This often includes perspectives from multiple viewpoints on a particular issue (distinguishing news reports from public relations or propaganda).  News reports in the [[ReportageNewsArticle]] sense de-emphasize the opinion of the author, with commentary and value judgements typically expressed elsewhere.\n\nA [[ReportageNewsArticle]] which goes deeper into analysis can also be marked with an additional type of [[AnalysisNewsArticle]].\n", "url": "https://schema.org/ReportageNewsArticle", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1525"], "contributor_urls": ["https://schema.org/docs/collab/TP"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:NewsArticle"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_reporteddoseschedule CONTENT {"term_key": "class_schema_reporteddoseschedule", "source_id": "schema:ReportedDoseSchedule", "term_kind": "class", "label": "ReportedDoseSchedule", "comment": "A patient-reported or observed dosing schedule for a drug or supplement.", "url": "https://schema.org/ReportedDoseSchedule", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:DoseSchedule"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
