UPSERT schema_term:class_schema_mediagallery CONTENT {"term_key": "class_schema_mediagallery", "source_id": "schema:MediaGallery", "term_kind": "class", "label": "MediaGallery", "comment": "Web page type: Media gallery page. A mixed-media page that can contain media such as images, videos, and other multimedia.", "url": "https://schema.org/MediaGallery", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CollectionPage"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_mediaobject CONTENT {"term_key": "class_schema_mediaobject", "source_id": "schema:MediaObject", "term_kind": "class", "label": "MediaObject", "comment": "A media object, such as an image, video, audio, or text object embedded in a web page or a downloadable dataset i.e. DataDownload. Note that a creative work may have many media objects associated with it on the same web page. For example, a page about a single song (MusicRecording) may have a music video (VideoObject), and a high and low bandwidth audio stream (2 AudioObject's).", "url": "https://schema.org/MediaObject", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_mediareview CONTENT {"term_key": "class_schema_mediareview", "source_id": "schema:MediaReview", "term_kind": "class", "label": "MediaReview", "comment": "A [[MediaReview]] is a more specialized form of Review dedicated to the evaluation of media content online, typically in the context of fact-checking and misinformation.\n    For more general reviews of media in the broader sense, use [[UserReview]], [[CriticReview]] or other [[Review]] types. This definition is\n    a work in progress. While the [[MediaManipulationRatingEnumeration]] list reflects significant community review amongst fact-checkers and others working\n    to combat misinformation, the specific structures for representing media objects, their versions and publication context, are still evolving. Similarly, best practices for the relationship between [[MediaReview]] and [[ClaimReview]] markup have not yet been finalized.", "url": "https://schema.org/MediaReview", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2450"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Review"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_mediareviewitem CONTENT {"term_key": "class_schema_mediareviewitem", "source_id": "schema:MediaReviewItem", "term_kind": "class", "label": "MediaReviewItem", "comment": "Represents an item or group of closely related items treated as a unit for the sake of evaluation in a [[MediaReview]]. Authorship etc. apply to the items rather than to the curation/grouping or reviewing party.", "url": "https://schema.org/MediaReviewItem", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2450"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_mediasubscription CONTENT {"term_key": "class_schema_mediasubscription", "source_id": "schema:MediaSubscription", "term_kind": "class", "label": "MediaSubscription", "comment": "A subscription which allows a user to access media including audio, video, books, etc.", "url": "https://schema.org/MediaSubscription", "is_part_of": null, "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1741"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Intangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalaudience CONTENT {"term_key": "class_schema_medicalaudience", "source_id": "schema:MedicalAudience", "term_kind": "class", "label": "MedicalAudience", "comment": "Target audiences for medical web pages.", "url": "https://schema.org/MedicalAudience", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Audience", "schema:PeopleAudience"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalbusiness CONTENT {"term_key": "class_schema_medicalbusiness", "source_id": "schema:MedicalBusiness", "term_kind": "class", "label": "MedicalBusiness", "comment": "A particular physical or virtual business of an organization for medical purposes. Examples of MedicalBusiness include different businesses run by health professionals.", "url": "https://schema.org/MedicalBusiness", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:LocalBusiness"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalcause CONTENT {"term_key": "class_schema_medicalcause", "source_id": "schema:MedicalCause", "term_kind": "class", "label": "MedicalCause", "comment": "The causative agent(s) that are responsible for the pathophysiologic process that eventually results in a medical condition, symptom or sign. In this schema, unless otherwise specified this is meant to be the proximate cause of the medical condition, symptom or sign. The proximate cause is defined as the causative agent that most directly results in the medical condition, symptom or sign. For example, the HIV virus could be considered a cause of AIDS. Or in a diagnostic context, if a patient fell and sustained a hip fracture and two days later sustained a pulmonary embolism which eventuated in a cardiac arrest, the cause of the cardiac arrest (the proximate cause) would be the pulmonary embolism and not the fall. Medical causes can include cardiovascular, chemical, dermatologic, endocrine, environmental, gastroenterologic, genetic, hematologic, gynecologic, iatrogenic, infectious, musculoskeletal, neurologic, nutritional, obstetric, oncologic, otolaryngologic, pharmacologic, psychiatric, pulmonary, renal, rheumatologic, toxic, traumatic, or urologic causes; medical conditions can be causes as well.", "url": "https://schema.org/MedicalCause", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalclinic CONTENT {"term_key": "class_schema_medicalclinic", "source_id": "schema:MedicalClinic", "term_kind": "class", "label": "MedicalClinic", "comment": "A facility, often associated with a hospital or medical school, that is devoted to the specific diagnosis and/or healthcare. Previously limited to outpatients but with evolution it may be open to inpatients as well.", "url": "https://schema.org/MedicalClinic", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalBusiness", "schema:MedicalOrganization"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalcode CONTENT {"term_key": "class_schema_medicalcode", "source_id": "schema:MedicalCode", "term_kind": "class", "label": "MedicalCode", "comment": "A code for a medical entity.", "url": "https://schema.org/MedicalCode", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalIntangible", "schema:CategoryCode"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalcondition CONTENT {"term_key": "class_schema_medicalcondition", "source_id": "schema:MedicalCondition", "term_kind": "class", "label": "MedicalCondition", "comment": "Any condition of the human body that affects the normal functioning of a person, whether physically or mentally. Includes diseases, injuries, disabilities, disorders, syndromes, etc.", "url": "https://schema.org/MedicalCondition", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalconditionstage CONTENT {"term_key": "class_schema_medicalconditionstage", "source_id": "schema:MedicalConditionStage", "term_kind": "class", "label": "MedicalConditionStage", "comment": "A stage of a medical condition, such as 'Stage IIIa'.", "url": "https://schema.org/MedicalConditionStage", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalIntangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalcontraindication CONTENT {"term_key": "class_schema_medicalcontraindication", "source_id": "schema:MedicalContraindication", "term_kind": "class", "label": "MedicalContraindication", "comment": "A condition or factor that serves as a reason to withhold a certain medical therapy. Contraindications can be absolute (there are no reasonable circumstances for undertaking a course of action) or relative (the patient is at higher risk of complications, but these risks may be outweighed by other considerations or mitigated by other measures).", "url": "https://schema.org/MedicalContraindication", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicaldevice CONTENT {"term_key": "class_schema_medicaldevice", "source_id": "schema:MedicalDevice", "term_kind": "class", "label": "MedicalDevice", "comment": "Any object used in a medical capacity, such as to diagnose or treat a patient.", "url": "https://schema.org/MedicalDevice", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalentity CONTENT {"term_key": "class_schema_medicalentity", "source_id": "schema:MedicalEntity", "term_kind": "class", "label": "MedicalEntity", "comment": "The most generic type of entity related to health and the practice of medicine.", "url": "https://schema.org/MedicalEntity", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Thing"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalguideline CONTENT {"term_key": "class_schema_medicalguideline", "source_id": "schema:MedicalGuideline", "term_kind": "class", "label": "MedicalGuideline", "comment": "Any recommendation made by a standard society (e.g. ACC/AHA) or consensus statement that denotes how to diagnose and treat a particular condition. Note: this type should be used to tag the actual guideline recommendation; if the guideline recommendation occurs in a larger scholarly article, use MedicalScholarlyArticle to tag the overall article, not this type. Note also: the organization making the recommendation should be captured in the recognizingAuthority base property of MedicalEntity.", "url": "https://schema.org/MedicalGuideline", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalguidelinecontraindication CONTENT {"term_key": "class_schema_medicalguidelinecontraindication", "source_id": "schema:MedicalGuidelineContraindication", "term_kind": "class", "label": "MedicalGuidelineContraindication", "comment": "A guideline contraindication that designates a process as harmful and where quality of the data supporting the contraindication is sound.", "url": "https://schema.org/MedicalGuidelineContraindication", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalGuideline"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalguidelinerecommendation CONTENT {"term_key": "class_schema_medicalguidelinerecommendation", "source_id": "schema:MedicalGuidelineRecommendation", "term_kind": "class", "label": "MedicalGuidelineRecommendation", "comment": "A guideline recommendation that is regarded as efficacious and where quality of the data supporting the recommendation is sound.", "url": "https://schema.org/MedicalGuidelineRecommendation", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalGuideline"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalindication CONTENT {"term_key": "class_schema_medicalindication", "source_id": "schema:MedicalIndication", "term_kind": "class", "label": "MedicalIndication", "comment": "A condition or factor that indicates use of a medical therapy, including signs, symptoms, risk factors, anatomical states, etc.", "url": "https://schema.org/MedicalIndication", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalintangible CONTENT {"term_key": "class_schema_medicalintangible", "source_id": "schema:MedicalIntangible", "term_kind": "class", "label": "MedicalIntangible", "comment": "A utility class that serves as the umbrella for a number of 'intangible' things in the medical space.", "url": "https://schema.org/MedicalIntangible", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalobservationalstudy CONTENT {"term_key": "class_schema_medicalobservationalstudy", "source_id": "schema:MedicalObservationalStudy", "term_kind": "class", "label": "MedicalObservationalStudy", "comment": "An observational study is a type of medical study that attempts to infer the possible effect of a treatment through observation of a cohort of subjects over a period of time. In an observational study, the assignment of subjects into treatment groups versus control groups is outside the control of the investigator. This is in contrast with controlled studies, such as the randomized controlled trials represented by MedicalTrial, where each subject is randomly assigned to a treatment group or a control group before the start of the treatment.", "url": "https://schema.org/MedicalObservationalStudy", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalStudy"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalorganization CONTENT {"term_key": "class_schema_medicalorganization", "source_id": "schema:MedicalOrganization", "term_kind": "class", "label": "MedicalOrganization", "comment": "A medical organization (physical or not), such as hospital, institution or clinic.", "url": "https://schema.org/MedicalOrganization", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Organization"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalprocedure CONTENT {"term_key": "class_schema_medicalprocedure", "source_id": "schema:MedicalProcedure", "term_kind": "class", "label": "MedicalProcedure", "comment": "A process of care used in either a diagnostic, therapeutic, preventive or palliative capacity that relies on invasive (surgical), non-invasive, or other techniques.", "url": "https://schema.org/MedicalProcedure", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalriskcalculator CONTENT {"term_key": "class_schema_medicalriskcalculator", "source_id": "schema:MedicalRiskCalculator", "term_kind": "class", "label": "MedicalRiskCalculator", "comment": "A complex mathematical calculation requiring an online calculator, used to assess prognosis. Note: use the url property of Thing to record any URLs for online calculators.", "url": "https://schema.org/MedicalRiskCalculator", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalRiskEstimator"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalriskestimator CONTENT {"term_key": "class_schema_medicalriskestimator", "source_id": "schema:MedicalRiskEstimator", "term_kind": "class", "label": "MedicalRiskEstimator", "comment": "Any rule set or interactive tool for estimating the risk of developing a complication or condition.", "url": "https://schema.org/MedicalRiskEstimator", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalriskfactor CONTENT {"term_key": "class_schema_medicalriskfactor", "source_id": "schema:MedicalRiskFactor", "term_kind": "class", "label": "MedicalRiskFactor", "comment": "A risk factor is anything that increases a person's likelihood of developing or contracting a disease, medical condition, or complication.", "url": "https://schema.org/MedicalRiskFactor", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalriskscore CONTENT {"term_key": "class_schema_medicalriskscore", "source_id": "schema:MedicalRiskScore", "term_kind": "class", "label": "MedicalRiskScore", "comment": "A simple system that adds up the number of risk factors to yield a score that is associated with prognosis, e.g. CHAD score, TIMI risk score.", "url": "https://schema.org/MedicalRiskScore", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalRiskEstimator"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalscholarlyarticle CONTENT {"term_key": "class_schema_medicalscholarlyarticle", "source_id": "schema:MedicalScholarlyArticle", "term_kind": "class", "label": "MedicalScholarlyArticle", "comment": "A scholarly article in the medical domain.", "url": "https://schema.org/MedicalScholarlyArticle", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:ScholarlyArticle"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalsign CONTENT {"term_key": "class_schema_medicalsign", "source_id": "schema:MedicalSign", "term_kind": "class", "label": "MedicalSign", "comment": "Any physical manifestation of a person's medical condition discoverable by objective diagnostic tests or physical examination.", "url": "https://schema.org/MedicalSign", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalSignOrSymptom"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalsignorsymptom CONTENT {"term_key": "class_schema_medicalsignorsymptom", "source_id": "schema:MedicalSignOrSymptom", "term_kind": "class", "label": "MedicalSignOrSymptom", "comment": "Any feature associated or not with a medical condition. In medicine a symptom is generally subjective while a sign is objective.", "url": "https://schema.org/MedicalSignOrSymptom", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalCondition"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalstudy CONTENT {"term_key": "class_schema_medicalstudy", "source_id": "schema:MedicalStudy", "term_kind": "class", "label": "MedicalStudy", "comment": "A medical study is an umbrella type covering all kinds of research studies relating to human medicine or health, including observational studies and interventional trials and registries, randomized, controlled or not. When the specific type of study is known, use one of the extensions of this type, such as MedicalTrial or MedicalObservationalStudy. Also, note that this type should be used to mark up data that describes the study itself; to tag an article that publishes the results of a study, use MedicalScholarlyArticle. Note: use the code property of MedicalEntity to store study IDs, e.g. clinicaltrials.gov ID.", "url": "https://schema.org/MedicalStudy", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicalsymptom CONTENT {"term_key": "class_schema_medicalsymptom", "source_id": "schema:MedicalSymptom", "term_kind": "class", "label": "MedicalSymptom", "comment": "Any complaint sensed and expressed by the patient (therefore defined as subjective)  like stomachache, lower-back pain, or fatigue.", "url": "https://schema.org/MedicalSymptom", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalSignOrSymptom"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_medicaltest CONTENT {"term_key": "class_schema_medicaltest", "source_id": "schema:MedicalTest", "term_kind": "class", "label": "MedicalTest", "comment": "Any medical test, typically performed for diagnostic purposes.", "url": "https://schema.org/MedicalTest", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
