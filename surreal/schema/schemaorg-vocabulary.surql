UPSERT schema_term:property_schema_maintainer CONTENT {"term_key": "property_schema_maintainer", "source_id": "schema:maintainer", "term_kind": "property", "label": "maintainer", "comment": "A maintainer of a [[Dataset]], software package ([[SoftwareApplication]]), or other [[Project]]. A maintainer is a [[Person]] or [[Organization]] that manages contributions to, and/or publication of, some (typically complex) artifact. It is common for distributions of software and data to be based on \"upstream\" sources. When [[maintainer]] is applied to a specific version of something e.g. a particular version or packaging of a [[Dataset]], it is always  possible that the upstream source has a different maintainer. The [[isBasedOn]] property can be used to indicate such relationships between datasets to make the different maintenance roles clear. Similarly in the case of software, a package may have dedicated maintainers working on integration into software distributions such as Ubuntu, as well as upstream maintainers of the underlying work.\n      ", "url": "https://schema.org/maintainer", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2311"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:CreativeWork"], "range_source_ids": ["schema:Organization", "schema:Person"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
