UPSERT schema_term:class_schema_protein CONTENT {"term_key": "class_schema_protein", "source_id": "schema:Protein", "term_kind": "class", "label": "Protein", "comment": "Protein is here used in its widest possible definition, as classes of amino acid based molecules. Amyloid-beta Protein in human (UniProt P05067), eukaryota (e.g. an OrthoDB group) or even a single molecule that one can point to are all of type :Protein. A protein can thus be a subclass of another protein, e.g. :Protein as a UniProt record can have multiple isoforms inside it which would also be :Protein. They can be imagined, synthetic, hypothetical or naturally occurring.", "url": "https://schema.org/Protein", "is_part_of": "https://pending.schema.org", "source_urls": ["http://bioschemas.org"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:BioChemEntity"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_psychologicaltreatment CONTENT {"term_key": "class_schema_psychologicaltreatment", "source_id": "schema:PsychologicalTreatment", "term_kind": "class", "label": "PsychologicalTreatment", "comment": "A process of care relying upon counseling, dialogue and communication  aimed at improving a mental health condition without use of drugs.", "url": "https://schema.org/PsychologicalTreatment", "is_part_of": "https://health-lifesci.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:TherapeuticProcedure"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
