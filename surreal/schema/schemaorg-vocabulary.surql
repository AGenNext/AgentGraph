UPSERT schema_term:property_schema_spatial CONTENT {"term_key": "property_schema_spatial", "source_id": "schema:spatial", "term_kind": "property", "label": "spatial", "comment": "The \"spatial\" property can be used in cases when more specific properties\n(e.g. [[locationCreated]], [[spatialCoverage]], [[contentLocation]]) are not known to be appropriate.", "url": "https://schema.org/spatial", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:CreativeWork"], "range_source_ids": ["schema:Place"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_spatialcoverage CONTENT {"term_key": "property_schema_spatialcoverage", "source_id": "schema:spatialCoverage", "term_kind": "property", "label": "spatialCoverage", "comment": "The spatialCoverage of a CreativeWork indicates the place(s) which are the focus of the content. It is a subproperty of\n      contentLocation intended primarily for more technical and detailed materials. For example with a Dataset, it indicates\n      areas that the dataset describes: a dataset of New York weather would have spatialCoverage which was the place: the state of New York.", "url": "https://schema.org/spatialCoverage", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:contentLocation"], "domain_source_ids": ["schema:CreativeWork"], "range_source_ids": ["schema:Place"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_speakable CONTENT {"term_key": "property_schema_speakable", "source_id": "schema:speakable", "term_kind": "property", "label": "speakable", "comment": "Indicates sections of a Web page that are particularly 'speakable' in the sense of being highlighted as being especially appropriate for text-to-speech conversion. Other sections of a page may also be usefully spoken in particular circumstances; the 'speakable' property serves to indicate the parts most likely to be generally useful for speech.\n\nThe *speakable* property can be repeated an arbitrary number of times, with three kinds of possible 'content-locator' values:\n\n1.) *id-value* URL references - uses *id-value* of an element in the page being annotated. The simplest use of *speakable* has (potentially relative) URL values, referencing identified sections of the document concerned.\n\n2.) CSS Selectors - addresses content in the annotated page, e.g. via class attribute. Use the [[cssSelector]] property.\n\n3.)  XPaths - addresses content via XPaths (assuming an XML view of the content). Use the [[xpath]] property.\n\n\nFor more sophisticated markup of speakable sections beyond simple ID references, either CSS selectors or XPath expressions to pick out document section(s) as speakable. For this\nwe define a supporting type, [[SpeakableSpecification]]  which is defined to be a possible value of the *speakable* property.\n         ", "url": "https://schema.org/speakable", "is_part_of": null, "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1389"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:WebPage", "schema:Article"], "range_source_ids": ["schema:URL", "schema:SpeakableSpecification"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_specialcommitments CONTENT {"term_key": "property_schema_specialcommitments", "source_id": "schema:specialCommitments", "term_kind": "property", "label": "specialCommitments", "comment": "Any special commitments associated with this job posting. Valid entries include VeteranCommit, MilitarySpouseCommit, etc.", "url": "https://schema.org/specialCommitments", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:JobPosting"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_specialopeninghoursspecification CONTENT {"term_key": "property_schema_specialopeninghoursspecification", "source_id": "schema:specialOpeningHoursSpecification", "term_kind": "property", "label": "specialOpeningHoursSpecification", "comment": "The special opening hours of a certain place.\\n\\nUse this to explicitly override general opening hours brought in scope by [[openingHoursSpecification]] or [[openingHours]].\n      ", "url": "https://schema.org/specialOpeningHoursSpecification", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Place"], "range_source_ids": ["schema:OpeningHoursSpecification"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
