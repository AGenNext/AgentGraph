UPSERT schema_term:class_schema_programmembership CONTENT {"term_key": "class_schema_programmembership", "source_id": "schema:ProgramMembership", "term_kind": "class", "label": "ProgramMembership", "comment": "Used to describe membership in a loyalty programs (e.g. \"StarAliance\"), traveler clubs (e.g. \"AAA\"), purchase clubs (\"Safeway Club\"), etc.", "url": "https://schema.org/ProgramMembership", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Intangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_project CONTENT {"term_key": "class_schema_project", "source_id": "schema:Project", "term_kind": "class", "label": "Project", "comment": "An enterprise (potentially individual but typically collaborative), planned to achieve a particular aim.\nUse properties from [[Organization]], [[subOrganization]]/[[parentOrganization]] to indicate project sub-structures. \n   ", "url": "https://schema.org/Project", "is_part_of": "https://pending.schema.org", "source_urls": ["https://schema.org/docs/collab/FundInfoCollab", "https://github.com/schemaorg/schemaorg/issues/383"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Organization"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
