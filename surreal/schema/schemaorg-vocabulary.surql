UPSERT schema_term:property_schema_geooverlaps CONTENT {"term_key": "property_schema_geooverlaps", "source_id": "schema:geoOverlaps", "term_kind": "property", "label": "geoOverlaps", "comment": "Represents a relationship between two geometries (or the places they represent), relating a geometry to another that geospatially overlaps it, i.e. they have some but not all points in common. As defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM).", "url": "https://schema.org/geoOverlaps", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "range_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
