UPSERT schema_term:class_schema_property CONTENT {"term_key": "class_schema_property", "source_id": "schema:Property", "term_kind": "class", "label": "Property", "comment": "A property, used to indicate attributes and relationships of some Thing; equivalent to rdf:Property.", "url": "https://schema.org/Property", "is_part_of": "https://meta.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Intangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_propertyvalue CONTENT {"term_key": "class_schema_propertyvalue", "source_id": "schema:PropertyValue", "term_kind": "class", "label": "PropertyValue", "comment": "A property-value pair, e.g. representing a feature of a product or place. Use the 'name' property for the name of the property. If there is an additional human-readable version of the value, put that into the 'description' property.\\n\\n Always use specific schema.org properties when a) they exist and b) you can populate them. Using PropertyValue as a substitute will typically not trigger the same effect as using the original, specific property.\n    ", "url": "https://schema.org/PropertyValue", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://blog.schema.org/2012/11/08/good-relations-and-schema-org/"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
