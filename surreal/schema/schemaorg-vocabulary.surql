UPSERT schema_term:class_schema_coverart CONTENT {"term_key": "class_schema_coverart", "source_id": "schema:CoverArt", "term_kind": "class", "label": "CoverArt", "comment": "The artwork on the outer surface of a CreativeWork.", "url": "https://schema.org/CoverArt", "is_part_of": "https://bib.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:VisualArtwork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_covidtestingfacility CONTENT {"term_key": "class_schema_covidtestingfacility", "source_id": "schema:CovidTestingFacility", "term_kind": "class", "label": "CovidTestingFacility", "comment": "A CovidTestingFacility is a [[MedicalClinic]] where testing for the COVID-19 Coronavirus\n      disease is available. If the facility is being made available from an established [[Pharmacy]], [[Hotel]], or other\n      non-medical organization, multiple types can be listed. This makes it easier to re-use existing schema.org information\n      about that place, e.g. contact info, address, opening hours. Note that in an emergency, such information may not always be reliable.\n      ", "url": "https://schema.org/CovidTestingFacility", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2490"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:MedicalClinic"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
