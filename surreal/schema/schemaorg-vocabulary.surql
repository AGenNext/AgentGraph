UPSERT schema_term:class_schema_pricespecification CONTENT {"term_key": "class_schema_pricespecification", "source_id": "schema:PriceSpecification", "term_kind": "class", "label": "PriceSpecification", "comment": "A structured value representing a price or price range. Typically, only the subclasses of this type are used for markup. It is recommended to use [[MonetaryAmount]] to describe independent amounts of money such as a salary, credit card limits, etc.", "url": "https://schema.org/PriceSpecification", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://blog.schema.org/2012/11/08/good-relations-and-schema-org/"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_product CONTENT {"term_key": "class_schema_product", "source_id": "schema:Product", "term_kind": "class", "label": "Product", "comment": "Any offered product or service. For example: a pair of shoes; a concert ticket; the rental of a car; a haircut; or an episode of a TV show streamed online.", "url": "https://schema.org/Product", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Thing"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_productcollection CONTENT {"term_key": "class_schema_productcollection", "source_id": "schema:ProductCollection", "term_kind": "class", "label": "ProductCollection", "comment": "A set of products (either [[ProductGroup]]s or specific variants) that are listed together e.g. in an [[Offer]].", "url": "https://schema.org/ProductCollection", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2597"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Collection", "schema:Product"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_productgroup CONTENT {"term_key": "class_schema_productgroup", "source_id": "schema:ProductGroup", "term_kind": "class", "label": "ProductGroup", "comment": "A ProductGroup represents a group of [[Product]]s that vary only in certain well-described ways, such as by [[size]], [[color]], [[material]] etc.\n\nWhile a ProductGroup itself is not directly offered for sale, the various varying products that it represents can be. The ProductGroup serves as a prototype or template, standing in for all of the products who have an [[isVariantOf]] relationship to it. As such, properties (including additional types) can be applied to the ProductGroup to represent characteristics shared by each of the (possibly very many) variants. Properties that reference a ProductGroup are not included in this mechanism; neither are the following specific properties [[variesBy]], [[hasVariant]], [[url]]. ", "url": "https://schema.org/ProductGroup", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1797"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Product", "cmns-col:Collection", "cmns-cls:Classifier"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_productmodel CONTENT {"term_key": "class_schema_productmodel", "source_id": "schema:ProductModel", "term_kind": "class", "label": "ProductModel", "comment": "A datasheet or vendor specification of a product (in the sense of a prototypical description).", "url": "https://schema.org/ProductModel", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://blog.schema.org/2012/11/08/good-relations-and-schema-org/"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Product"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_professionalservice CONTENT {"term_key": "class_schema_professionalservice", "source_id": "schema:ProfessionalService", "term_kind": "class", "label": "ProfessionalService", "comment": "Original definition: \"provider of professional services.\"\\n\\nThe general [[ProfessionalService]] type for local businesses was deprecated due to confusion with [[Service]]. For reference, the types that it included were: [[Dentist]],\n        [[AccountingService]], [[Attorney]], [[Notary]], as well as types for several kinds of [[HomeAndConstructionBusiness]]: [[Electrician]], [[GeneralContractor]],\n        [[HousePainter]], [[Locksmith]], [[Plumber]], [[RoofingContractor]]. [[LegalService]] was introduced as a more inclusive supertype of [[Attorney]].", "url": "https://schema.org/ProfessionalService", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:LocalBusiness"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
