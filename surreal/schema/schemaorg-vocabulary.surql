UPSERT schema_term:property_schema_energyefficiencyscalemax CONTENT {"term_key": "property_schema_energyefficiencyscalemax", "source_id": "schema:energyEfficiencyScaleMax", "term_kind": "property", "label": "energyEfficiencyScaleMax", "comment": "Specifies the most energy efficient class on the regulated EU energy consumption scale for the product category a product belongs to. For example, energy consumption for televisions placed on the market after January 1, 2020 is scaled from D to A+++.", "url": "https://schema.org/energyEfficiencyScaleMax", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2670"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:EnergyConsumptionDetails"], "range_source_ids": ["schema:EUEnergyEfficiencyEnumeration"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
