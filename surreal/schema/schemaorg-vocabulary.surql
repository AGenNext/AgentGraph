UPSERT schema_term:class_schema_governmentoffice CONTENT {"term_key": "class_schema_governmentoffice", "source_id": "schema:GovernmentOffice", "term_kind": "class", "label": "GovernmentOffice", "comment": "A government office&#x2014;for example, an IRS or DMV office.", "url": "https://schema.org/GovernmentOffice", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:LocalBusiness"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
