UPSERT schema_term:enumeration_value_schema_dangerousgoodconsideration CONTENT {"term_key": "enumeration_value_schema_dangerousgoodconsideration", "source_id": "schema:DangerousGoodConsideration", "term_kind": "enumeration_value", "label": "DangerousGoodConsideration", "comment": "The item is dangerous and requires careful handling and/or special training of the user. See also the [UN Model Classification](https://unece.org/DAM/trans/danger/publi/unrec/rev17/English/02EREv17_Part2.pdf) defining the 9 classes of dangerous goods such as explosives, gases, flammables, and more.", "url": "https://schema.org/DangerousGoodConsideration", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2989"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["schema:AdultOrientedEnumeration"], "parent_source_ids": ["schema:AdultOrientedEnumeration"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:enumeration_value_schema_datadrivenmediadigitalsource CONTENT {"term_key": "enumeration_value_schema_datadrivenmediadigitalsource", "source_id": "schema:DataDrivenMediaDigitalSource", "term_kind": "enumeration_value", "label": "DataDrivenMediaDigitalSource", "comment": "Content coded as '<a href=\"https://cv.iptc.org/newscodes/digitalsourcetype/dataDrivenMedia\">data driven media</a>' using the IPTC <a href=\"https://cv.iptc.org/newscodes/digitalsourcetype/\">digital source type</a> vocabulary.", "url": "https://schema.org/DataDrivenMediaDigitalSource", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/3392"], "contributor_urls": [], "exact_match_urls": ["http://cv.iptc.org/newscodes/digitalsourcetype/dataDrivenMedia"], "raw_types": ["schema:IPTCDigitalSourceEnumeration"], "parent_source_ids": ["schema:IPTCDigitalSourceEnumeration"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:enumeration_value_schema_decontextualizedcontent CONTENT {"term_key": "enumeration_value_schema_decontextualizedcontent", "source_id": "schema:DecontextualizedContent", "term_kind": "enumeration_value", "label": "DecontextualizedContent", "comment": "Content coded 'missing context' in a [[MediaReview]], considered in the context of how it was published or shared.\n\nFor a [[VideoObject]] to be 'missing context': Presenting unaltered video in an inaccurate manner that misrepresents the footage. For example, using incorrect dates or locations, altering the transcript or sharing brief clips from a longer video to mislead viewers. (A video rated 'original' can also be missing context.)\n\nFor an [[ImageObject]] to be 'missing context': Presenting unaltered images in an inaccurate manner to misrepresent the image and mislead the viewer. For example, a common tactic is using an unaltered image but saying it came from a different time or place. (An image rated 'original' can also be missing context.)\n\nFor an [[ImageObject]] with embedded text to be 'missing context': An unaltered image presented in an inaccurate manner to misrepresent the image and mislead the viewer. For example, a common tactic is using an unaltered image but saying it came from a different time or place. (An 'original' image with inaccurate text would generally fall in this category.)\n\nFor an [[AudioObject]] to be 'missing context': Unaltered audio presented in an inaccurate manner that misrepresents it. For example, using incorrect dates or locations, or sharing brief clips from a longer recording to mislead viewers. (Audio rated “original” can also be missing context.)\n", "url": "https://schema.org/DecontextualizedContent", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2450"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["schema:MediaManipulationRatingEnumeration"], "parent_source_ids": ["schema:MediaManipulationRatingEnumeration"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:enumeration_value_schema_definitivelegalvalue CONTENT {"term_key": "enumeration_value_schema_definitivelegalvalue", "source_id": "schema:DefinitiveLegalValue", "term_kind": "enumeration_value", "label": "DefinitiveLegalValue", "comment": "Indicates a document for which the text is conclusively what the law says and is legally binding. (e.g. The digitally signed version of an Official Journal.)\n  Something \"Definitive\" is considered to be also [[AuthoritativeLegalValue]].", "url": "https://schema.org/DefinitiveLegalValue", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1156", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:LegalValue-definitive"], "raw_types": ["schema:LegalValueLevel"], "parent_source_ids": ["schema:LegalValueLevel"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
