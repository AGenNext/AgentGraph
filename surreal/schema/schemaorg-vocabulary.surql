UPSERT schema_term:class_schema_geocircle CONTENT {"term_key": "class_schema_geocircle", "source_id": "schema:GeoCircle", "term_kind": "class", "label": "GeoCircle", "comment": "A GeoCircle is a GeoShape representing a circular geographic area. As it is a GeoShape\n          it provides the simple textual property 'circle', but also allows the combination of postalCode alongside geoRadius.\n          The center of the circle can be indicated via the 'geoMidpoint' property, or more approximately using 'address', 'postalCode'.\n       ", "url": "https://schema.org/GeoCircle", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:GeoShape"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_geocoordinates CONTENT {"term_key": "class_schema_geocoordinates", "source_id": "schema:GeoCoordinates", "term_kind": "class", "label": "GeoCoordinates", "comment": "The geographic coordinates of a place or event.", "url": "https://schema.org/GeoCoordinates", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_geoshape CONTENT {"term_key": "class_schema_geoshape", "source_id": "schema:GeoShape", "term_kind": "class", "label": "GeoShape", "comment": "The geographic shape of a place. A GeoShape can be described using several properties whose values are based on latitude/longitude pairs. Either whitespace or commas can be used to separate latitude and longitude; whitespace should be used when writing a list of several such points.", "url": "https://schema.org/GeoShape", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/rNews"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_geospatialgeometry CONTENT {"term_key": "class_schema_geospatialgeometry", "source_id": "schema:GeospatialGeometry", "term_kind": "class", "label": "GeospatialGeometry", "comment": "(Eventually to be defined as) a supertype of GeoShape designed to accommodate definitions from Geo-Spatial best practices.", "url": "https://schema.org/GeospatialGeometry", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1375"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Intangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_giveaction CONTENT {"term_key": "class_schema_giveaction", "source_id": "schema:GiveAction", "term_kind": "class", "label": "GiveAction", "comment": "The act of transferring ownership of an object to a destination. Reciprocal of TakeAction.\\n\\nRelated actions:\\n\\n* [[TakeAction]]: Reciprocal of GiveAction.\\n* [[SendAction]]: Unlike SendAction, GiveAction implies that ownership is being transferred (e.g. I may send my laptop to you, but that doesn't mean I'm giving it to you).", "url": "https://schema.org/GiveAction", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:TransferAction"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
