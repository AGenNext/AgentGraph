UPSERT schema_term:property_schema_openinghours CONTENT {"term_key": "property_schema_openinghours", "source_id": "schema:openingHours", "term_kind": "property", "label": "openingHours", "comment": "The general opening hours for a business. Opening hours can be specified as a weekly time range, starting with days, then times per day. Multiple days can be listed with commas ',' separating each day. Day or time ranges are specified using a hyphen '-'.\\n\\n* Days are specified using the following two-letter combinations: ```Mo```, ```Tu```, ```We```, ```Th```, ```Fr```, ```Sa```, ```Su```.\\n* Times are specified using 24:00 format. For example, 3pm is specified as ```15:00```, 10am as ```10:00```. \\n* Here is an example: <code>&lt;time itemprop=\"openingHours\" datetime=&quot;Tu,Th 16:00-20:00&quot;&gt;Tuesdays and Thursdays 4-8pm&lt;/time&gt;</code>.\\n* If a business is open 7 days a week, then it can be specified as <code>&lt;time itemprop=&quot;openingHours&quot; datetime=&quot;Mo-Su&quot;&gt;Monday through Sunday, all day&lt;/time&gt;</code>.", "url": "https://schema.org/openingHours", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:CivicStructure", "schema:LocalBusiness"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_openinghoursspecification CONTENT {"term_key": "property_schema_openinghoursspecification", "source_id": "schema:openingHoursSpecification", "term_kind": "property", "label": "openingHoursSpecification", "comment": "The opening hours of a certain place.", "url": "https://schema.org/openingHoursSpecification", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Place"], "range_source_ids": ["schema:OpeningHoursSpecification"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
