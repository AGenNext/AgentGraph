UPSERT schema_term:property_schema_directapply CONTENT {"term_key": "property_schema_directapply", "source_id": "schema:directApply", "term_kind": "property", "label": "directApply", "comment": "Indicates whether an [[url]] that is associated with a [[JobPosting]] enables direct application for the job, via the posting website. A job posting is considered to have directApply of [[True]] if an application process for the specified job can be directly initiated via the url(s) given (noting that e.g. multiple internet domains might nevertheless be involved at an implementation level). A value of [[False]] is appropriate if there is no clear path to applying directly online for the specified job, navigating directly from the JobPosting url(s) supplied.", "url": "https://schema.org/directApply", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2907"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:JobPosting"], "range_source_ids": ["schema:Boolean"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
