UPSERT schema_term:property_schema_freeshippingthreshold CONTENT {"term_key": "property_schema_freeshippingthreshold", "source_id": "schema:freeShippingThreshold", "term_kind": "property", "label": "freeShippingThreshold", "comment": "A monetary value above (or at) which the shipping rate becomes free. Intended to be used via an [[OfferShippingDetails]] with [[shippingSettingsLink]] matching this [[ShippingRateSettings]].", "url": "https://schema.org/freeShippingThreshold", "is_part_of": null, "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2506"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:ShippingRateSettings"], "range_source_ids": ["schema:DeliveryChargeSpecification", "schema:MonetaryAmount"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
