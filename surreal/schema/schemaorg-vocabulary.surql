UPSERT schema_term:property_schema_endtime CONTENT {"term_key": "property_schema_endtime", "source_id": "schema:endTime", "term_kind": "property", "label": "endTime", "comment": "The endTime of something. For a reserved event or service (e.g. FoodEstablishmentReservation), the time that it is expected to end. For actions that span a period of time, when the action was performed. E.g. John wrote a book from January to *December*. For media, including audio and video, it's the time offset of the end of a clip within a larger file.\\n\\nNote that Event uses startDate/endDate instead of startTime/endTime, even when describing dates with times. This situation may be clarified in future revisions.", "url": "https://schema.org/endTime", "is_part_of": null, "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2493"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:InteractionCounter", "schema:Schedule", "schema:Action", "schema:FoodEstablishmentReservation", "schema:MediaObject"], "range_source_ids": ["schema:DateTime", "schema:Time"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
