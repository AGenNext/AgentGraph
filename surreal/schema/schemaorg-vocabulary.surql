UPSERT schema_term:class_schema_definedregion CONTENT {"term_key": "class_schema_definedregion", "source_id": "schema:DefinedRegion", "term_kind": "class", "label": "DefinedRegion", "comment": "A DefinedRegion is a geographic area defined by potentially arbitrary (rather than political, administrative or natural geographical) criteria. Properties are provided for defining a region by reference to sets of postal codes.\n\nExamples: a delivery destination when shopping. Region where regional pricing is configured.\n\nRequirement 1:\nCountry: US\nStates: \"NY\", \"CA\"\n\nRequirement 2:\nCountry: US\nPostalCode Set: { [94000-94585], [97000, 97999], [13000, 13599]}\n{ [12345, 12345], [78945, 78945], }\nRegion = state, canton, prefecture, autonomous community...\n", "url": "https://schema.org/DefinedRegion", "is_part_of": null, "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2506"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Place", "schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_definedterm CONTENT {"term_key": "class_schema_definedterm", "source_id": "schema:DefinedTerm", "term_kind": "class", "label": "DefinedTerm", "comment": "A word, name, acronym, phrase, etc. with a formal definition. Often used in the context of category or subject classification, glossaries or dictionaries, product or creative work types, etc. Use the name property for the term being defined, use termCode if the term has an alpha-numeric code allocated, use description to provide the definition of the term. Use the about property to specify what the term is about.", "url": "https://schema.org/DefinedTerm", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/894"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Intangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:class_schema_definedtermset CONTENT {"term_key": "class_schema_definedtermset", "source_id": "schema:DefinedTermSet", "term_kind": "class", "label": "DefinedTermSet", "comment": "A set of defined terms, for example a set of categories or a classification scheme, a glossary, dictionary or enumeration. Use the about property to specify what the term set is about.", "url": "https://schema.org/DefinedTermSet", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/894"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
