UPSERT schema_term:property_schema_geocontains CONTENT {"term_key": "property_schema_geocontains", "source_id": "schema:geoContains", "term_kind": "property", "label": "geoContains", "comment": "Represents a relationship between two geometries (or the places they represent), relating a containing geometry to a contained geometry. \"a contains b iff no points of b lie in the exterior of a, and at least one point of the interior of b lies in the interior of a\". As defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM).", "url": "https://schema.org/geoContains", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "range_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_geocoveredby CONTENT {"term_key": "property_schema_geocoveredby", "source_id": "schema:geoCoveredBy", "term_kind": "property", "label": "geoCoveredBy", "comment": "Represents a relationship between two geometries (or the places they represent), relating a geometry to another that covers it. As defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM).", "url": "https://schema.org/geoCoveredBy", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "range_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_geocovers CONTENT {"term_key": "property_schema_geocovers", "source_id": "schema:geoCovers", "term_kind": "property", "label": "geoCovers", "comment": "Represents a relationship between two geometries (or the places they represent), relating a covering geometry to a covered geometry. \"Every point of b is a point of (the interior or boundary of) a\". As defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM).", "url": "https://schema.org/geoCovers", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "range_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_geocrosses CONTENT {"term_key": "property_schema_geocrosses", "source_id": "schema:geoCrosses", "term_kind": "property", "label": "geoCrosses", "comment": "Represents a relationship between two geometries (or the places they represent), relating a geometry to another that crosses it: \"a crosses b: they have some but not all interior points in common, and the dimension of the intersection is less than that of at least one of them\". As defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM).", "url": "https://schema.org/geoCrosses", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "range_source_ids": ["schema:GeospatialGeometry", "schema:Place"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_geodisjoint CONTENT {"term_key": "property_schema_geodisjoint", "source_id": "schema:geoDisjoint", "term_kind": "property", "label": "geoDisjoint", "comment": "Represents spatial relations in which two geometries (or the places they represent) are topologically disjoint: \"they have no point in common. They form a set of disconnected geometries.\" (A symmetric relationship, as defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM).)", "url": "https://schema.org/geoDisjoint", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "range_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_geoequals CONTENT {"term_key": "property_schema_geoequals", "source_id": "schema:geoEquals", "term_kind": "property", "label": "geoEquals", "comment": "Represents spatial relations in which two geometries (or the places they represent) are topologically equal, as defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM). \"Two geometries are topologically equal if their interiors intersect and no part of the interior or boundary of one geometry intersects the exterior of the other\" (a symmetric relationship).", "url": "https://schema.org/geoEquals", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "range_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_geointersects CONTENT {"term_key": "property_schema_geointersects", "source_id": "schema:geoIntersects", "term_kind": "property", "label": "geoIntersects", "comment": "Represents spatial relations in which two geometries (or the places they represent) have at least one point in common. As defined in [DE-9IM](https://en.wikipedia.org/wiki/DE-9IM).", "url": "https://schema.org/geoIntersects", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "range_source_ids": ["schema:Place", "schema:GeospatialGeometry"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
