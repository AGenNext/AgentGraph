UPSERT schema_term:property_schema_itemoffered CONTENT {"term_key": "property_schema_itemoffered", "source_id": "schema:itemOffered", "term_kind": "property", "label": "itemOffered", "comment": "An item being offered (or demanded). The transactional nature of the offer or demand is documented using [[businessFunction]], e.g. sell, lease etc. While several common expected types are listed explicitly in this definition, others can be used. Using a second type, such as Product or a subtype of Product, can clarify the nature of the offer.", "url": "https://schema.org/itemOffered", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Offer", "schema:Demand"], "range_source_ids": ["schema:MenuItem", "schema:Trip", "schema:Event", "schema:CreativeWork", "schema:Product", "schema:Service", "schema:AggregateOffer"], "inverse_source_ids": ["schema:offers"], "superseded_by_source_ids": [], "pending": false, "external": false};
