UPSERT schema_term:property_schema_measuredproperty CONTENT {"term_key": "property_schema_measuredproperty", "source_id": "schema:measuredProperty", "term_kind": "property", "label": "measuredProperty", "comment": "The measuredProperty of an [[Observation]], typically via its [[StatisticalVariable]]. There are various kinds of applicable [[Property]]: a schema.org property, a property from other RDF-compatible systems, e.g. W3C RDF Data Cube, Data Commons, Wikidata, or schema.org extensions such as [GS1's](https://www.gs1.org/voc/?show=properties).", "url": "https://schema.org/measuredProperty", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2291"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Observation", "schema:StatisticalVariable"], "range_source_ids": ["schema:Property"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
