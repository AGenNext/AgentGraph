UPSERT schema_term:class_schema_shippingratesettings CONTENT {"term_key": "class_schema_shippingratesettings", "source_id": "schema:ShippingRateSettings", "term_kind": "class", "label": "ShippingRateSettings", "comment": "A ShippingRateSettings represents re-usable pieces of shipping information. It is designed for publication on an URL that may be referenced via the [[shippingSettingsLink]] property of an [[OfferShippingDetails]]. Several occurrences can be published, distinguished and matched (i.e. identified/referenced) by their different values for [[shippingLabel]].", "url": "https://schema.org/ShippingRateSettings", "is_part_of": null, "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2506"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
