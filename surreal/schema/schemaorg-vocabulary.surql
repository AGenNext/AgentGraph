UPSERT schema_term:class_schema_hostel CONTENT {"term_key": "class_schema_hostel", "source_id": "schema:Hostel", "term_kind": "class", "label": "Hostel", "comment": "A hostel - cheap accommodation, often in shared dormitories.\n<br /><br />\nSee also the <a href=\"/docs/hotels.html\">dedicated document on the use of schema.org for marking up hotels and other forms of accommodations</a>.\n", "url": "https://schema.org/Hostel", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:LodgingBusiness"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
