UPSERT schema_term:property_schema_observationperiod CONTENT {"term_key": "property_schema_observationperiod", "source_id": "schema:observationPeriod", "term_kind": "property", "label": "observationPeriod", "comment": "The length of time an Observation took place over. The format follows `P[0-9]*[Y|M|D|h|m|s]`. For example, P1Y is Period 1 Year, P3M is Period 3 Months, P3h is Period 3 hours.", "url": "https://schema.org/observationPeriod", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2564"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Observation"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_occupancy CONTENT {"term_key": "property_schema_occupancy", "source_id": "schema:occupancy", "term_kind": "property", "label": "occupancy", "comment": "The allowed total occupancy for the accommodation in persons (including infants etc). For individual accommodations, this is not necessarily the legal maximum but defines the permitted usage as per the contractual agreement (e.g. a double room used by a single person).\nTypical unit code(s): C62 for person.", "url": "https://schema.org/occupancy", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/STI_Accommodation_Ontology"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Suite", "schema:SingleFamilyResidence", "schema:Accommodation", "schema:HotelRoom", "schema:Apartment"], "range_source_ids": ["schema:QuantitativeValue"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_occupationlocation CONTENT {"term_key": "property_schema_occupationlocation", "source_id": "schema:occupationLocation", "term_kind": "property", "label": "occupationLocation", "comment": " The region/country for which this occupational description is appropriate. Note that educational requirements and qualifications can vary between jurisdictions.", "url": "https://schema.org/occupationLocation", "is_part_of": null, "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1698"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Occupation"], "range_source_ids": ["schema:AdministrativeArea"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_occupationalcategory CONTENT {"term_key": "property_schema_occupationalcategory", "source_id": "schema:occupationalCategory", "term_kind": "property", "label": "occupationalCategory", "comment": "A category describing the job, preferably using a term from a taxonomy such as [BLS O*NET-SOC](http://www.onetcenter.org/taxonomy.html), [ISCO-08](https://www.ilo.org/public/english/bureau/stat/isco/isco08/) or similar, with the property repeated for each applicable value. Ideally the taxonomy should be identified, and both the textual label and formal code for the category should be provided.\\n\nNote: for historical reasons, any textual label and formal code provided as a literal may be assumed to be from O*NET-SOC.", "url": "https://schema.org/occupationalCategory", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2289", "https://github.com/schemaorg/schemaorg/issues/2460", "https://github.com/schemaorg/schemaorg/issues/3420", "https://github.com/schemaorg/schemaorg/issues/2192", "https://github.com/schemaorg/schemaorg/issues/1698"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:WorkBasedProgram", "schema:Occupation", "schema:Physician", "schema:JobPosting", "schema:EducationalOccupationalProgram"], "range_source_ids": ["schema:CategoryCode", "schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_occupationalcredentialawarded CONTENT {"term_key": "property_schema_occupationalcredentialawarded", "source_id": "schema:occupationalCredentialAwarded", "term_kind": "property", "label": "occupationalCredentialAwarded", "comment": "A description of the qualification, award, certificate, diploma or other occupational credential awarded as a consequence of successful completion of this course or program.", "url": "https://schema.org/occupationalCredentialAwarded", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2289"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Course", "schema:EducationalOccupationalProgram"], "range_source_ids": ["schema:EducationalOccupationalCredential", "schema:Text", "schema:URL"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
