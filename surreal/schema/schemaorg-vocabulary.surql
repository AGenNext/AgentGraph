UPSERT schema_term:property_schema_ineligibleregion CONTENT {"term_key": "property_schema_ineligibleregion", "source_id": "schema:ineligibleRegion", "term_kind": "property", "label": "ineligibleRegion", "comment": "The ISO 3166-1 (ISO 3166-1 alpha-2) or ISO 3166-2 code, the place, or the GeoShape for the geo-political region(s) for which the offer or delivery charge specification is not valid, e.g. a region where the transaction is not allowed.\\n\\nSee also [[eligibleRegion]].\n      ", "url": "https://schema.org/ineligibleRegion", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2242"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:MediaObject", "schema:Offer", "schema:ActionAccessSpecification", "schema:DeliveryChargeSpecification", "schema:Demand"], "range_source_ids": ["schema:Place", "schema:Text", "schema:GeoShape"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
