UPSERT schema_term:property_schema_size CONTENT {"term_key": "property_schema_size", "source_id": "schema:size", "term_kind": "property", "label": "size", "comment": "A standardized size of a product or creative work, specified either through a simple textual string (for example 'XL', '32Wx34L'), a  QuantitativeValue with a unitCode, or a comprehensive and structured [[SizeSpecification]]; in other cases, the [[width]], [[height]], [[depth]] and [[weight]] properties may be more applicable. ", "url": "https://schema.org/size", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1797"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:CreativeWork", "schema:Product"], "range_source_ids": ["schema:DefinedTerm", "schema:QuantitativeValue", "schema:SizeSpecification", "schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_sizegroup CONTENT {"term_key": "property_schema_sizegroup", "source_id": "schema:sizeGroup", "term_kind": "property", "label": "sizeGroup", "comment": "The size group (also known as \"size type\") for a product's size. Size groups are common in the fashion industry to define size segments and suggested audiences for wearable products. Multiple values can be combined, for example \"men's big and tall\", \"petite maternity\" or \"regular\".", "url": "https://schema.org/sizeGroup", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2811"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:SizeSpecification"], "range_source_ids": ["schema:SizeGroupEnumeration", "schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_sizesystem CONTENT {"term_key": "property_schema_sizesystem", "source_id": "schema:sizeSystem", "term_kind": "property", "label": "sizeSystem", "comment": "The size system used to identify a product's size. Typically either a standard (for example, \"GS1\" or \"ISO-EN13402\"), country code (for example \"US\" or \"JP\"), or a measuring system (for example \"Metric\" or \"Imperial\").", "url": "https://schema.org/sizeSystem", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2811"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:SizeSpecification"], "range_source_ids": ["schema:Text", "schema:SizeSystemEnumeration"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
