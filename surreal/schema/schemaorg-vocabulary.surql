UPSERT schema_term:class_schema_howtoitem CONTENT {"term_key": "class_schema_howtoitem", "source_id": "schema:HowToItem", "term_kind": "class", "label": "HowToItem", "comment": "An item used as either a tool or supply when performing the instructions for how to achieve a result.", "url": "https://schema.org/HowToItem", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:ListItem"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_howtosection CONTENT {"term_key": "class_schema_howtosection", "source_id": "schema:HowToSection", "term_kind": "class", "label": "HowToSection", "comment": "A sub-grouping of steps in the instructions for how to achieve a result (e.g. steps for making a pie crust within a pie recipe).", "url": "https://schema.org/HowToSection", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork", "schema:ItemList", "schema:ListItem"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_howtostep CONTENT {"term_key": "class_schema_howtostep", "source_id": "schema:HowToStep", "term_kind": "class", "label": "HowToStep", "comment": "A step in the instructions for how to achieve a result. It is an ordered list with HowToDirection and/or HowToTip items.", "url": "https://schema.org/HowToStep", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:ListItem", "schema:CreativeWork", "schema:ItemList"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_howtosupply CONTENT {"term_key": "class_schema_howtosupply", "source_id": "schema:HowToSupply", "term_kind": "class", "label": "HowToSupply", "comment": "A supply consumed when performing the instructions for how to achieve a result.", "url": "https://schema.org/HowToSupply", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:HowToItem"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_howtotip CONTENT {"term_key": "class_schema_howtotip", "source_id": "schema:HowToTip", "term_kind": "class", "label": "HowToTip", "comment": "An explanation in the instructions for how to achieve a result. It provides supplementary information about a technique, supply, author's preference, etc. It can explain what could be done, or what should not be done, but doesn't specify what should be done (see HowToDirection).", "url": "https://schema.org/HowToTip", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:CreativeWork", "schema:ListItem"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
