UPSERT schema_term:property_schema_torque CONTENT {"term_key": "property_schema_torque", "source_id": "schema:torque", "term_kind": "property", "label": "torque", "comment": "The torque (turning force) of the vehicle's engine.\\n\\nTypical unit code(s): NU for newton metre (N m), F17 for pound-force per foot, or F48 for pound-force per inch\\n\\n* Note 1: You can link to information about how the given value has been determined (e.g. reference RPM) using the [[valueReference]] property.\\n* Note 2: You can use [[minValue]] and [[maxValue]] to indicate ranges.", "url": "https://schema.org/torque", "is_part_of": "https://auto.schema.org", "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/Automotive_Ontology_Working_Group"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:EngineSpecification"], "range_source_ids": ["schema:QuantitativeValue"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
