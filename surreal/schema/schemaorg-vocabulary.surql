UPSERT schema_term:class_schema_buyaction CONTENT {"term_key": "class_schema_buyaction", "source_id": "schema:BuyAction", "term_kind": "class", "label": "BuyAction", "comment": "The act of giving money to a seller in exchange for goods or services rendered. An agent buys an object, product, or service from a seller for a price. Reciprocal of SellAction.", "url": "https://schema.org/BuyAction", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:TradeAction"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_cdcpmdrecord CONTENT {"term_key": "class_schema_cdcpmdrecord", "source_id": "schema:CDCPMDRecord", "term_kind": "class", "label": "CDCPMDRecord", "comment": "A CDCPMDRecord is a data structure representing a record in a CDC tabular data format\n      used for hospital data reporting. See [documentation](/docs/cdc-covid.html) for details, and the linked CDC materials for authoritative\n      definitions used as the source here.\n      ", "url": "https://schema.org/CDCPMDRecord", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2521"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
