UPSERT schema_term:property_schema_temporalcoverage CONTENT {"term_key": "property_schema_temporalcoverage", "source_id": "schema:temporalCoverage", "term_kind": "property", "label": "temporalCoverage", "comment": "The temporalCoverage of a CreativeWork indicates the period that the content applies to, i.e. that it describes, either as a DateTime or as a textual string indicating a time period in [ISO 8601 time interval format](https://en.wikipedia.org/wiki/ISO_8601#Time_intervals). In\n      the case of a Dataset it will typically indicate the relevant time period in a precise notation (e.g. for a 2011 census dataset, the year 2011 would be written \"2011/2012\"). Other forms of content, e.g. ScholarlyArticle, Book, TVSeries or TVEpisode, may indicate their temporalCoverage in broader terms - textually or via well-known URL.\n      Written works such as books may sometimes have precise temporal coverage too, e.g. a work set in 1939 - 1945 can be indicated in ISO 8601 interval format format via \"1939/1945\".\n\nOpen-ended date ranges can be written with \"..\" in place of the end date. For example, \"2015-11/..\" indicates a range beginning in November 2015 and with no specified final date. This is tentative and might be updated in future when ISO 8601 is officially updated.", "url": "https://schema.org/temporalCoverage", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:CreativeWork"], "range_source_ids": ["schema:Text", "schema:URL", "schema:DateTime"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_termcode CONTENT {"term_key": "property_schema_termcode", "source_id": "schema:termCode", "term_kind": "property", "label": "termCode", "comment": "A code that identifies this [[DefinedTerm]] within a [[DefinedTermSet]].", "url": "https://schema.org/termCode", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/894"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:DefinedTerm"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_termduration CONTENT {"term_key": "property_schema_termduration", "source_id": "schema:termDuration", "term_kind": "property", "label": "termDuration", "comment": "The amount of time in a term as defined by the institution. A term is a length of time where students take one or more classes. Semesters and quarters are common units for term.", "url": "https://schema.org/termDuration", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2419"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:EducationalOccupationalProgram"], "range_source_ids": ["schema:Duration"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
