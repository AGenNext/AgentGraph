UPSERT schema_term:property_schema_lowprice CONTENT {"term_key": "property_schema_lowprice", "source_id": "schema:lowPrice", "term_kind": "property", "label": "lowPrice", "comment": "The lowest price of all offers available.\\n\\nUsage guidelines:\\n\\n* Use values from 0123456789 (Unicode 'DIGIT ZERO' (U+0030) to 'DIGIT NINE' (U+0039)) rather than superficially similar Unicode symbols.\\n* Use '.' (Unicode 'FULL STOP' (U+002E)) rather than ',' to indicate a decimal point. Avoid using these symbols as a readability separator.", "url": "https://schema.org/lowPrice", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["cmns-q:hasLowerBound", "fibo-fnd-acc-cur:hasMonetaryAmount"], "domain_source_ids": ["schema:AggregateOffer"], "range_source_ids": ["schema:Text", "schema:Number"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
