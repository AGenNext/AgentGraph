UPSERT schema_term:property_schema_titleeidr CONTENT {"term_key": "property_schema_titleeidr", "source_id": "schema:titleEIDR", "term_kind": "property", "label": "titleEIDR", "comment": "An [EIDR](https://eidr.org/) (Entertainment Identifier Registry) [[identifier]] representing at the most general/abstract level, a work of film or television.\n\nFor example, the motion picture known as \"Ghostbusters\" has a titleEIDR of  \"10.5240/7EC7-228A-510A-053E-CBB8-J\". This title (or work) may have several variants, which EIDR calls \"edits\". See [[editEIDR]].\n\nSince schema.org types like [[Movie]], [[TVEpisode]], [[TVSeason]], and [[TVSeries]] can be used for both works and their multiple expressions, it is possible to use [[titleEIDR]] alone (for a general description), or alongside [[editEIDR]] for a more edit-specific description.\n", "url": "https://schema.org/titleEIDR", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2469"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:identifier"], "domain_source_ids": ["schema:Movie", "schema:TVSeason", "schema:TVSeries", "schema:TVEpisode"], "range_source_ids": ["schema:Text", "schema:URL"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
