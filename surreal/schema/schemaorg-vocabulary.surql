UPSERT schema_term:property_schema_legislationamends CONTENT {"term_key": "property_schema_legislationamends", "source_id": "schema:legislationAmends", "term_kind": "property", "label": "legislationAmends", "comment": "Another legislation that this legislation amends, introducing legal changes.", "url": "https://schema.org/legislationAmends", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2698", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:amends"], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:legislationChanges"], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Legislation"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationapplies CONTENT {"term_key": "property_schema_legislationapplies", "source_id": "schema:legislationApplies", "term_kind": "property", "label": "legislationApplies", "comment": "Indicates that this legislation (or part of a legislation) somehow transfers another legislation in a different legislative context. This is an informative link, and it has no legal value. For legally-binding links of transposition, use the <a href=\"/legislationTransposes\">legislationTransposes</a> property. For example an informative consolidated law of a European Union's member state \"applies\" the consolidated version of the European Directive implemented in it.", "url": "https://schema.org/legislationApplies", "is_part_of": "https://pending.schema.org", "source_urls": ["https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli", "https://github.com/schemaorg/schemaorg/issues/1156"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:implements"], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Legislation"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationchanges CONTENT {"term_key": "property_schema_legislationchanges", "source_id": "schema:legislationChanges", "term_kind": "property", "label": "legislationChanges", "comment": "Another legislation that this legislation changes. This encompasses the notions of amendment, replacement, correction, repeal, or other types of change. This may be a direct change (textual or non-textual amendment) or a consequential or indirect change. The property is to be used to express the existence of a change relationship between two acts rather than the existence of a consolidated version of the text that shows the result of the change. For consolidation relationships, use the <a href=\"/legislationConsolidates\">legislationConsolidates</a> property.", "url": "https://schema.org/legislationChanges", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1156", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:changes"], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Legislation"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationcommences CONTENT {"term_key": "property_schema_legislationcommences", "source_id": "schema:legislationCommences", "term_kind": "property", "label": "legislationCommences", "comment": "Another legislation that this one sets into force.", "url": "https://schema.org/legislationCommences", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2698", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:commences"], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:legislationChanges"], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Legislation"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationconsolidates CONTENT {"term_key": "property_schema_legislationconsolidates", "source_id": "schema:legislationConsolidates", "term_kind": "property", "label": "legislationConsolidates", "comment": "Indicates another legislation taken into account in this consolidated legislation (which is usually the product of an editorial process that revises the legislation). This property should be used multiple times to refer to both the original version or the previous consolidated version, and to the legislations making the change.", "url": "https://schema.org/legislationConsolidates", "is_part_of": "https://pending.schema.org", "source_urls": ["https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli", "https://github.com/schemaorg/schemaorg/issues/1156"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:consolidates"], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Legislation"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationcorrects CONTENT {"term_key": "property_schema_legislationcorrects", "source_id": "schema:legislationCorrects", "term_kind": "property", "label": "legislationCorrects", "comment": "Another legislation in which this one introduces textual changes, like correction of spelling mistakes, with no legal impact (for modifications that have legal impact, use <a href=\"/legislationAmends\">legislationAmends</a>).", "url": "https://schema.org/legislationCorrects", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2698", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:corrects"], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Legislation"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationcountersignedby CONTENT {"term_key": "property_schema_legislationcountersignedby", "source_id": "schema:legislationCountersignedBy", "term_kind": "property", "label": "legislationCountersignedBy", "comment": "The person or organization that countersigned the legislation. Depending on the legal context, a countersignature can indicate that the signed authority undertakes to assume responsibility for texts emanating from a person who is inviolable and irresponsible, (for example a King, Grand Duc or President), or that the authority is in charge of the implementation of the text.", "url": "https://schema.org/legislationCountersignedBy", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2698", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:countersigned_by"], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Organization", "schema:Person"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationdate CONTENT {"term_key": "property_schema_legislationdate", "source_id": "schema:legislationDate", "term_kind": "property", "label": "legislationDate", "comment": "The date of adoption or signature of the legislation. This is the date at which the text is officially aknowledged to be a legislation, even though it might not even be published or in force.", "url": "https://schema.org/legislationDate", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1156", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:date_document"], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:dateCreated"], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Date"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_legislationdateofapplicability CONTENT {"term_key": "property_schema_legislationdateofapplicability", "source_id": "schema:legislationDateOfApplicability", "term_kind": "property", "label": "legislationDateOfApplicability", "comment": "The date at which the Legislation becomes applicable. This can sometimes be distinct from the date of entry into force : a text may come in force today, and state it will become applicable in 3 months.", "url": "https://schema.org/legislationDateOfApplicability", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2698", "https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:date_applicability"], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Date"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
