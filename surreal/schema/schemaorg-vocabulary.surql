UPSERT schema_term:property_schema_legislationensuresimplementationof CONTENT {"term_key": "property_schema_legislationensuresimplementationof", "source_id": "schema:legislationEnsuresImplementationOf", "term_kind": "property", "label": "legislationEnsuresImplementationOf", "comment": "Indicates that this Legislation ensures the implementation of another Legislation, for example by modifying national legislations so that they do not contradict to an EU regulation or decision. This implies a legal meaning. Transpositions of EU Directive should be captured with <a href=\"/legislationTransposes\">legislationTransposes</a>.", "url": "https://schema.org/legislationEnsuresImplementationOf", "is_part_of": "https://pending.schema.org", "source_urls": ["https://op.europa.eu/en/web/eu-vocabularies/model/-/resource/dataset/eli", "https://github.com/schemaorg/schemaorg/issues/2698"], "contributor_urls": ["https://schema.org/docs/collab/ELI"], "exact_match_urls": ["eli:ensures_implementation_of"], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:legislationApplies"], "domain_source_ids": ["schema:Legislation"], "range_source_ids": ["schema:Legislation"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
