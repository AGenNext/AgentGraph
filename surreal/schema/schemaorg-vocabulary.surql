UPSERT schema_term:class_schema_meetingroom CONTENT {"term_key": "class_schema_meetingroom", "source_id": "schema:MeetingRoom", "term_kind": "class", "label": "MeetingRoom", "comment": "A meeting room, conference room, or conference hall is a room provided for singular events such as business conferences and meetings (source: Wikipedia, the free encyclopedia, see <a href=\"http://en.wikipedia.org/wiki/Conference_hall\">http://en.wikipedia.org/wiki/Conference_hall</a>).\n<br /><br />\nSee also the <a href=\"/docs/hotels.html\">dedicated document on the use of schema.org for marking up hotels and other forms of accommodations</a>.\n", "url": "https://schema.org/MeetingRoom", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/STI_Accommodation_Ontology"], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Room"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_memberprogram CONTENT {"term_key": "class_schema_memberprogram", "source_id": "schema:MemberProgram", "term_kind": "class", "label": "MemberProgram", "comment": "A MemberProgram defines a loyalty (or membership) program that provides its members with certain benefits, for example better pricing, free shipping or returns, or the ability to earn loyalty points. Member programs may have multiple tiers, for example silver and gold members, each with different benefits.", "url": "https://schema.org/MemberProgram", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/3563"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Intangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
