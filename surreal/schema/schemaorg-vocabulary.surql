UPSERT schema_term:class_schema_reservation CONTENT {"term_key": "class_schema_reservation", "source_id": "schema:Reservation", "term_kind": "class", "label": "Reservation", "comment": "Describes a reservation for travel, dining or an event. Some reservations require tickets. \\n\\nNote: This type is for information about actual reservations, e.g. in confirmation emails or HTML pages with individual confirmations of reservations. For offers of tickets, restaurant reservations, flights, or rental cars, use [[Offer]].", "url": "https://schema.org/Reservation", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Intangible"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_reservationpackage CONTENT {"term_key": "class_schema_reservationpackage", "source_id": "schema:ReservationPackage", "term_kind": "class", "label": "ReservationPackage", "comment": "A group of multiple reservations with common values for all sub-reservations.", "url": "https://schema.org/ReservationPackage", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Reservation"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_reserveaction CONTENT {"term_key": "class_schema_reserveaction", "source_id": "schema:ReserveAction", "term_kind": "class", "label": "ReserveAction", "comment": "Reserving a concrete object.\\n\\nRelated actions:\\n\\n* [[ScheduleAction]]: Unlike ScheduleAction, ReserveAction reserves concrete objects (e.g. a table, a hotel) towards a time slot / spatial allocation.", "url": "https://schema.org/ReserveAction", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:PlanAction"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_reservoir CONTENT {"term_key": "class_schema_reservoir", "source_id": "schema:Reservoir", "term_kind": "class", "label": "Reservoir", "comment": "A reservoir of water, typically an artificially created lake, like the Lake Kariba reservoir.", "url": "https://schema.org/Reservoir", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:BodyOfWater"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
