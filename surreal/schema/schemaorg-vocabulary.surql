UPSERT schema_term:property_schema_graceperiod CONTENT {"term_key": "property_schema_graceperiod", "source_id": "schema:gracePeriod", "term_kind": "property", "label": "gracePeriod", "comment": "The period of time after any due date that the borrower has to fulfil its obligations before a default (failure to pay) is deemed to have occurred.", "url": "https://schema.org/gracePeriod", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/1253"], "contributor_urls": ["https://schema.org/docs/collab/FIBO"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": [], "domain_source_ids": ["schema:LoanOrCredit"], "range_source_ids": ["schema:Duration"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
