UPSERT schema_term:property_schema_gtin CONTENT {"term_key": "property_schema_gtin", "source_id": "schema:gtin", "term_kind": "property", "label": "gtin", "comment": "A Global Trade Item Number ([GTIN](https://www.gs1.org/standards/id-keys/gtin)). GTINs identify trade items, including products and services, using numeric identification codes.\n\nA correct [[gtin]] value should be a valid GTIN, which means that it should be an all-numeric string of either 8, 12, 13 or 14 digits, or a \"GS1 Digital Link\" URL based on such a string. The numeric component should also have a [valid GS1 check digit](https://www.gs1.org/services/check-digit-calculator) and meet the other rules for valid GTINs. See also [GS1's GTIN Summary](http://www.gs1.org/barcodes/technical/idkeys/gtin) and [Wikipedia](https://en.wikipedia.org/wiki/Global_Trade_Item_Number) for more details. Left-padding of the gtin values is not required or encouraged. The [[gtin]] property generalizes the earlier [[gtin8]], [[gtin12]], [[gtin13]], and [[gtin14]] properties.\n\nThe GS1 [digital link specifications](https://www.gs1.org/standards/Digital-Link/) expresses GTINs as URLs (URIs, IRIs, etc.).\nDigital Links should be populated into the [[hasGS1DigitalLink]] attribute.\n\nNote also that this is a definition for how to include GTINs in Schema.org data, and not a definition of GTINs in general - see the GS1 documentation for authoritative details.", "url": "https://schema.org/gtin", "is_part_of": "https://pending.schema.org", "source_urls": ["https://github.com/schemaorg/schemaorg/issues/2288"], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:identifier"], "domain_source_ids": ["schema:Offer", "schema:Demand", "schema:Product"], "range_source_ids": ["schema:Text", "schema:URL"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": true, "external": false};
UPSERT schema_term:property_schema_gtin12 CONTENT {"term_key": "property_schema_gtin12", "source_id": "schema:gtin12", "term_kind": "property", "label": "gtin12", "comment": "The GTIN-12 code of the product, or the product to which the offer refers. The GTIN-12 is the 12-digit GS1 Identification Key composed of a U.P.C. Company Prefix, Item Reference, and Check Digit used to identify trade items. See [GS1 GTIN Summary](http://www.gs1.org/barcodes/technical/idkeys/gtin) for more details.", "url": "https://schema.org/gtin12", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:identifier", "schema:gtin"], "domain_source_ids": ["schema:Demand", "schema:Product", "schema:Offer"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_gtin13 CONTENT {"term_key": "property_schema_gtin13", "source_id": "schema:gtin13", "term_kind": "property", "label": "gtin13", "comment": "The GTIN-13 code of the product, or the product to which the offer refers. This is equivalent to 13-digit ISBN codes and EAN UCC-13. Former 12-digit UPC codes can be converted into a GTIN-13 code by simply adding a preceding zero. See [GS1 GTIN Summary](http://www.gs1.org/barcodes/technical/idkeys/gtin) for more details.", "url": "https://schema.org/gtin13", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:gtin", "schema:identifier"], "domain_source_ids": ["schema:Product", "schema:Offer", "schema:Demand"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_gtin14 CONTENT {"term_key": "property_schema_gtin14", "source_id": "schema:gtin14", "term_kind": "property", "label": "gtin14", "comment": "The GTIN-14 code of the product, or the product to which the offer refers. See [GS1 GTIN Summary](http://www.gs1.org/barcodes/technical/idkeys/gtin) for more details.", "url": "https://schema.org/gtin14", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:gtin", "schema:identifier"], "domain_source_ids": ["schema:Product", "schema:Offer", "schema:Demand"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:property_schema_gtin8 CONTENT {"term_key": "property_schema_gtin8", "source_id": "schema:gtin8", "term_kind": "property", "label": "gtin8", "comment": "The GTIN-8 code of the product, or the product to which the offer refers. This code is also known as EAN/UCC-8 or 8-digit EAN. See [GS1 GTIN Summary](http://www.gs1.org/barcodes/technical/idkeys/gtin) for more details.", "url": "https://schema.org/gtin8", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/GoodRelationsTerms"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:gtin", "schema:identifier"], "domain_source_ids": ["schema:Offer", "schema:Demand", "schema:Product"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
