UPSERT schema_term:property_schema_issn CONTENT {"term_key": "property_schema_issn", "source_id": "schema:issn", "term_kind": "property", "label": "issn", "comment": "The International Standard Serial Number (ISSN) that identifies this serial publication. You can repeat this property to identify different formats of, or the linking ISSN (ISSN-L) for, this serial publication.", "url": "https://schema.org/issn", "is_part_of": null, "source_urls": [], "contributor_urls": ["https://schema.org/docs/collab/bibex"], "exact_match_urls": [], "raw_types": ["rdf:Property"], "parent_source_ids": ["schema:identifier"], "domain_source_ids": ["schema:Dataset", "schema:WebSite", "schema:CreativeWorkSeries", "schema:Blog"], "range_source_ids": ["schema:Text"], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
