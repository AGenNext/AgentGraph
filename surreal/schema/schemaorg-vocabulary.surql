UPSERT schema_term:class_schema_datedmoneyspecification CONTENT {"term_key": "class_schema_datedmoneyspecification", "source_id": "schema:DatedMoneySpecification", "term_kind": "class", "label": "DatedMoneySpecification", "comment": "A DatedMoneySpecification represents monetary values with optional start and end dates. For example, this could represent an employee's salary over a specific period of time. __Note:__ This type has been superseded by [[MonetaryAmount]], use of that type is recommended.", "url": "https://schema.org/DatedMoneySpecification", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:StructuredValue"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": ["schema:MonetaryAmount"], "superseded_by_source_ids": ["schema:MonetaryAmount"], "pending": false, "external": false};
