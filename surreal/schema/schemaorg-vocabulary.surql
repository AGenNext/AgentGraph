UPSERT schema_term:class_schema_sendaction CONTENT {"term_key": "class_schema_sendaction", "source_id": "schema:SendAction", "term_kind": "class", "label": "SendAction", "comment": "The act of physically/electronically dispatching an object for transfer from an origin to a destination. Related actions:\\n\\n* [[ReceiveAction]]: The reciprocal of SendAction.\\n* [[GiveAction]]: Unlike GiveAction, SendAction does not imply the transfer of ownership (e.g. I can send you my laptop, but I'm not necessarily giving it to you).", "url": "https://schema.org/SendAction", "is_part_of": null, "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:TransferAction"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
UPSERT schema_term:class_schema_sequentialart CONTENT {"term_key": "class_schema_sequentialart", "source_id": "schema:SequentialArt", "term_kind": "class", "label": "SequentialArt", "comment": "An art forms that use images deployed in a specific order for the purpose of graphic storytelling (i.e., narration of graphic stories) or conveying information. Examples of SequentialArt are Franco-Belgian Bande Dessinée, Comics in the USA and 漫画 (Manga) in Japan.", "url": "https://schema.org/SequentialArt", "is_part_of": "https://bib.schema.org", "source_urls": [], "contributor_urls": [], "exact_match_urls": [], "raw_types": ["rdfs:Class"], "parent_source_ids": ["schema:Book", "schema:VisualArtwork"], "domain_source_ids": [], "range_source_ids": [], "inverse_source_ids": [], "superseded_by_source_ids": [], "pending": false, "external": false};
