// Extended Schema for AGenNext - New Models, Options, Relations

generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core Models ─────────────────────────────────────────

model Task {
  id          String   @id @default(uuid())
  status      TaskStatus
  framework  FrameworkType
  submission Json    // Full TaskSubmission JSON
  context    Json?   // TaskContext when provided
  result     Json?   // Execution result
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  checkpoints Checkpoint[]
  learnings   Learning[]
  agentTasks  AgentTask[]
}

model Checkpoint {
  id            Int     @id @default(autoincrement())
  taskId        String
  step         Int
  nodeId       String?  // Current node in workflow
  state        Json?   // Workflow state snapshot
  learnings    String[]
  decisions   Json[]
  mistakesFixed Json[]
  context     Json?
  savedAt     DateTime @default(now())

  task        Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Learning {
  id        Int     @id @default(autoincrement())
  taskId    String
  learning String
  source   String?  // "auto", "human", "system"
  createdAt DateTime @default(now())

  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Agent & Workflow ───────────────────────────────────

model AgentTask {
  id          String   @id @default(uuid())
  taskId      String
  agentId     String   // Agent identifier
  framework  FrameworkType
  config     Json?    // Agent config (nodes, edges, etc.)
  status     AgentTaskStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  traces    AgentTrace[]
}

model AgentTrace {
  id          Int     @id @default(autoincrement())
  agentTaskId String
  step       Int
  node       String   // Current node
  action     String?  // Action taken
  result     Json?   // Node result
  duration   Int?    // ms
  createdAt  DateTime @default(now())

  agentTask  AgentTask @relation(fields: [agentTaskId], references: [id], onDelete: Cascade)
}

// ─── Human-in-the-Loop ─────────────────────────────

model ApprovalRequest {
  id          String   @id @default(uuid())
  taskId      String
  nodeId     String?  // Node requiring approval
  status     ApprovalStatus @default(PENDING)
  requester  String?   // Who requested
  approver   String?   // Who approved
  comment   String?
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model HumanFeedback {
  id          Int     @id @default(autoincrement())
  taskId      String
  rating     Int?     // 1-5
  comment    String?
  createdAt   DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Enums ─────────────────────────────────────────

enum TaskStatus {
  PENDING_CONTEXT
  RUNNING
  COMPLETED
  STOPPED
  FAILED
}

enum FrameworkType {
  LANGGRAPH
  LANGCHAIN
  AUTOGEN
  CREWAI
  OPENAI
  ANTHROPIC
  GOOGLE
  MICROSOFT
  LLAMAINDEX
  SALESFORCE
  SMOLAGENTS
  CUSTOM
}

enum AgentTaskStatus {
  PENDING
  RUNNING
  WAITING_HUMAN
  COMPLETED
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}