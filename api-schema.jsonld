  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Content Writing Multi-Agent Team",
      "alternateName": "AGenNext-Registry",
      "description": "Multi-agent content writing team with LangGraph orchestration and A2A protocol",
