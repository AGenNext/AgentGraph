    },
    {
      "@type": "APIReference",
      "name": "Content Writing Team API",
      "description": "REST API for multi-agent content writing team",
      "url": "https://api.content-team.example.com",
      "runtimePlatform": "https://work-1-hynxtypfdhcaoqvf.prod-runtime.all-hands.dev",
      "provider": {
        "@type": "Organization",
        "name": "AGenNext"
      },
      "version": "1.0.0",
      "protocolSupported": "A2A Protocol",
      "programmingLanguage": "Python"
    },
    {
      "@type": "WebAPI",
      "name": "Agent Operations",
      "description": "Create and run agent tasks",
