      "applicationSubCategory": "AI Agent Framework",
      "operatingSystem": ["Linux", "macOS", "Windows"],
      "programmingLanguage": ["Python"],
      "softwareRequirements": [
        "Python 3.11+",
        "OpenAI SDK",
        "LangGraph",
        "A2A Protocol"
      ],
      "featureList": [
        "15+ SDK Agents",
        "LangGraph Orchestration",
        "A2A Protocol",
