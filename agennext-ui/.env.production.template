# AGenNext Production Environment Variables

# === REQUIRED ===
# API Keys (use secrets manager in production)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === SECURITY ===
# Generate: openssl rand -base64 32
API_SECRET_KEY=
JWT_SECRET=

# === DATABASE ===
DATABASE_URL=postgresql://user:pass@localhost:5432/agennext
REDIS_URL=redis://localhost:6379

# === NETWORK ===
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# === RATE LIMITING ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# === MONITORING ===
SENTRY_DSN=
DATADOG_API_KEY=

# === FEATURES ===
ENABLE_ANALYTICS=true
ENABLE_CACHE=true
DEBUG=false