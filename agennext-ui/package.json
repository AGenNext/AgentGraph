{
  "name": "agennext-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && docker build -t agennext/ui .",
    "docker:build": "docker build -t agennext-ui:latest .",
    "docker:run": "docker run -d -p 3000:3000 --name agennext-ui agennext-ui:latest"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@xyflow/react": "^12.10.2",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "playwright": "^1.59.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
